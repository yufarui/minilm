{
  "output_dir": "checkpoints/pretrain",
  "run_name": "minilm-pretrain",
  "seed": 42,
  "data_seed": 42,
  "ignore_data_skip": false,
  "accelerator_config": {
    "use_seedable_sampler": true
  },
  "do_train": true,
  "do_eval": true,
  "bf16": true,
  "per_device_train_batch_size": 32,
  "per_device_eval_batch_size": 32,
  "gradient_accumulation_steps": 1,
  "learning_rate": 2e-5,
  "weight_decay": 0.01,
  "max_grad_norm": 1,
  "lr_scheduler_type": "cosine",
  "logging_steps": 20,
  "logging_first_step": true,
  "save_strategy": "steps",
  "eval_strategy": "steps",
  "save_steps": 2000,
  "eval_steps": 5000,
  "max_steps": 13000,
  "warmup_steps": 3000,
  "save_total_limit": 3,
  "gradient_checkpointing": false,
  "prediction_loss_only": true,
  "dataloader_num_workers": 0,
  "report_to": "swanlab"
}
